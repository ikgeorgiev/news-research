# Copy this file to .env and replace the placeholder passwords before using
# anything outside your own machine.
POSTGRES_USER=cef
POSTGRES_PASSWORD=change-me-before-sharing
POSTGRES_DB=cef_news
POSTGRES_PORT=5433

DATABASE_URL=postgresql+psycopg://cef:change-me-before-sharing@127.0.0.1:5433/cef_news
TICKERS_CSV_PATH=/app/data/cef_tickers.csv

INGEST_COOLDOWN_SECONDS=5
INGESTION_STALE_RUN_TIMEOUT_SECONDS=3600
INGESTION_MAX_WORKERS=4
INGESTION_PARALLEL_YAHOO=false
INGESTION_ENABLE_CONDITIONAL_GET=true
FEED_FETCH_MAX_ATTEMPTS=3
FEED_FETCH_BACKOFF_SECONDS=1.0
FEED_FETCH_BACKOFF_JITTER_SECONDS=0.3
PUSH_SEND_TIMEOUT_SECONDS=10
PUSH_MAX_PER_CYCLE=25
PUSH_MAX_CONSECUTIVE_FAILURES=20
RAW_FEED_RETENTION_DAYS=30
RAW_FEED_PRUNE_BATCH_SIZE=5000
RAW_FEED_PRUNE_MAX_BATCHES=5
RAW_FEED_PRUNE_INTERVAL_SECONDS=3600
YAHOO_CHUNK_SIZE=40
SOURCE_ENABLE_YAHOO=true
SOURCE_ENABLE_PRN=true
SOURCE_ENABLE_GN=true
SOURCE_ENABLE_BW=true
SCHEDULER_ENABLED=true
INGESTION_ADVISORY_LOCK_KEY=1715171517
MIGRATION_ADVISORY_LOCK_KEY=1715171519
ADMIN_API_KEY=
BEHIND_PROXY=false
TRUSTED_PROXY_IPS=

CORS_ORIGINS=http://localhost:3005,http://127.0.0.1:3005
FRONTEND_PORT=3005
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8001

GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-before-sharing
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=
